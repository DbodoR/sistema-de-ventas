<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox minHeight="-Infinity" minWidth="-Infinity" prefHeight="602.0" prefWidth="873.0" spacing="15.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.dbodor.sistemadeventas.Controllers.InventarioController">
   <children>
      <Label styleClass="h2" text="Inventario" />
      <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0" spacing="5.0">
         <children>
            <Label text="Buscar producto" />
            <TextField fx:id="txtBuscar" prefWidth="350.0" promptText="Código de barras o nombre" />
            <Button fx:id="btnProducto" mnemonicParsing="false" onAction="#buscarProducto" styleClass="btn-primary, btn-sm" text="Buscar" />
         </children>
      </HBox>
      <TableView prefHeight="200.0" prefWidth="200.0" styleClass="table-condensed" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="colCodigo" prefWidth="75.0" text="Código" />
          <TableColumn fx:id="colProducto" prefWidth="75.0" text="Producto" />
            <TableColumn fx:id="colCategoria" prefWidth="75.0" text="Categoria" />
            <TableColumn fx:id="colCosto" prefWidth="75.0" text="Costo" />
            <TableColumn fx:id="colPrecio" prefWidth="75.0" text="Precio venta" />
            <TableColumn fx:id="colStock" prefWidth="75.0" text="Stock" />
            <TableColumn fx:id="colAccion" prefWidth="75.0" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
