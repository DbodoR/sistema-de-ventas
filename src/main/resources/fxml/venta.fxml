<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox minHeight="-Infinity" minWidth="-Infinity" prefHeight="886.0" prefWidth="1196.0" spacing="15.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>
      <Label styleClass="h2" text="Punto de venta">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>
      <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0" spacing="10.0">
         <children>
            <Label text="Buscar producto">
               <font>
                  <Font size="14.0" />
               </font>
            </Label>
            <TextField fx:id="txtBuscar" prefWidth="350.0" promptText="Código de barras o nombre" />
            <Button fx:id="btnProducto" mnemonicParsing="false" styleClass="btn-primary, btn-sm" text="Agregar" />
         </children>
      </HBox>
      <TableView fx:id="tablaVenta" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="colCodigo" prefWidth="75.0" text="Código" />
          <TableColumn fx:id="colProducto" prefWidth="75.0" text="Producto" />
            <TableColumn fx:id="colPrecio" prefWidth="75.0" text="Precio Unidad" />
            <TableColumn fx:id="colCantidad" prefWidth="75.0" text="Cantidad" />
            <TableColumn fx:id="colSubtotal" prefWidth="75.0" text="Subtotal" />
            <TableColumn fx:id="colAcciones" prefWidth="75.0" text="Acción" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
         <styleClass>
            <String fx:value="table-condensed" />
            <String fx:value="TableView" />
         </styleClass>
      </TableView>
      <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0" spacing="20.0">
         <children>
            <Button fx:id="btnCancelar" mnemonicParsing="false" styleClass="btn-danger, btn-lg" text="Cancelar Venta" />
            <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
            <Label text="TOTAL A PAGAR:">
               <font>
                  <Font size="18.0" />
               </font>
            </Label>
            <Label fx:id="lblTotal" text="\$ 0.00" textFill="#28a745">
               <font>
                  <Font name="System Bold" size="32.0" />
               </font>
            </Label>
            <Button fx:id="btnCobrar" mnemonicParsing="false" styleClass="btn-success, btn-lg" text="Cobrar" />
         </children>
      </HBox>
   </children>
</VBox>
