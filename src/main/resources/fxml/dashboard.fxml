<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.dbodor.sistemadeventas.Controllers.DashboardController">
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0" spacing="10.0" styleClass="panel-primary" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="btnVenta" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#ventanaVenta" styleClass="btn-primary, btn-lg" text="Venta">
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor></Button>
            <Button fx:id="btnInventario" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" styleClass="btn-primary, btn-lg" text="Inventario">
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor></Button>
            <Button fx:id="btnGuardarArticulo" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#ventanaIngresarProducto" styleClass="btn-primary, btn-lg" text="Ingresar articulo">
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor></Button>
            <Button fx:id="btnGraficas" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" styleClass="btn-primary, btn-lg" text="Gráficas">
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor></Button>
            <Button fx:id="btnCerrar" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#cerrarCaja" text="Cerrar caja">
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor>
               <styleClass>
                  <String fx:value="btn-danger" />
                  <String fx:value="btn-lg" />
               </styleClass></Button>
         </children>
         <BorderPane.margin>
            <Insets />
         </BorderPane.margin>
         <padding>
            <Insets bottom="5.0" left="10.0" />
         </padding>
      </HBox>
   </top>
   <center>
      <StackPane fx:id="areaContenido" prefHeight="150.0" prefWidth="200.0" BorderPane.alignment="CENTER" />
   </center>
</BorderPane>
